[CUDA.global]
    trace_mode = TRACING
    CUDA.device = (0, 16)

[CUDA(contextdevice).default]
    CUDA_context_create = off
    CUDA_context_destroy = off
    CUDA_device_init = off
    CUDA_device_reset = off
    CUDA_device_synchronize = off

[CUDA(streamevent).default]
    CUDA_stream_create = off
    CUDA_stream_destroy = off
    CUDA_stream_synchronize = off
    CUDA_event_create = off
    CUDA_event_record = off
    CUDA_event_synchronize = off
    CUDA_event_destroy = off

[CUDA(memcpy).default]
    CUDA_memcpy_HtoD = on
    CUDA_memcpy_DtoH = on
    CUDA_memcpy_DtoD = on
    CUDA_memcpy_HtoH = on
    CUDA_memcpy_async = on

[CUDA(malloc).default]
    CUDA_memset = off
    CUDA_malloc = off
    CUDA_free = off
    CUDA_malloc_host = off
    CUDA_free_host = off
    CUDA_malloc_managed = off

[CUDA(kernel).default]
    CUDA_kernel_launch = on
    CUDA_kernel_complete = off
    CUDA_kernel_enqueue = off

[CUDA(others).default]
    CUDA_api_enter = off
    CUDA_api_exit = off
    CUDA_driver_call = off
    CUDA_runtime_call = off
    CUDA_synchronize = off
    CUDA_context_push = off
    CUDA_context_pop = off
    CUDA_module_load = off
    CUDA_module_unload = off
    CUDA_function_load = off
    CUDA_graph_create = off
    CUDA_graph_launch = off
    CUDA_graph_destroy = off
    CUDA_unified_memory_migrate = off
    CUDA_unified_memory_prefetch = off
    CUDA_nvtx_range_push = off
    CUDA_nvtx_range_pop = off
    CUDA_nvtx_mark = off

