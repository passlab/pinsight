# Based on: https://github.com/github/gitignore

# Ignored filetypes
# -----------------

# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# CMake output
*.cmake
CMakeCache.txt
CMakeFiles/*

build/
.idea/
cmake-build-debug/

# Trace output directories
traces/

# IDE / Editor
.idea/
.cproject
.project
tracecompass/
.tracecompass/

# clangd index cache
.cache/

# compile_commands.json is a build artifact (symlink into build/)
compile_commands.json
Makefile

# Scratch / one-off output files in project root or src/
tmp.diff
paper_text.txt
trace_config.txt
pinsight_trace_config.txt
src/final_verification.txt
src/multi_punit_output.txt
src/parser_output.txt
src/CMakeFiles/

# Built test binaries and intermediate CUDA build files
test/hello/helloomp
test/jacobi/jacobi
test/jacobi/OpenMP_trace_config.install
test/trace_config_parse/test_parser
test/trace_config_parse/trace_config.txt
test/vecadd/
test/vecaddcuda

# Built experiment binaries
experiment/backtrace/backtrace
experiment/backtrace/backtrace_dlinfo
experiment/backtrace/backtrace_libunwind

# Local benchmark repo clones (not submodules — just local checkouts)
eva/AMG/
eva/Kripke/
eva/Quicksilver/
eva/cuda-samples/
eva/mlperfhpc/
eva/warpx/
test/LULESH/
test/cuda-samples/
